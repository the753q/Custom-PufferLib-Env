{
    "name": "PufferLib Custom Env Development",
    "image": "pufferai/puffertank:4.0",
    
    "initializeCommand": "xhost +local:",

    "runArgs": [
        "--init",
        "--gpus=all",
        "--ipc=host",
        "--network=host"
    ],

    // Mount PufferLib, X11 sockets, and XDG runtime directory (for Wayland and Mutter/Xwayland auth)
    "mounts": [
        "source=${localWorkspaceFolder}/../PufferLib,target=/puffertank/pufferlib,type=bind",
        "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
        "source=${localEnv:XDG_RUNTIME_DIR},target=/run/user/1000,type=bind"
    ],

    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}",
        "XAUTHORITY": "${localEnv:XAUTHORITY}",
        "WAYLAND_DISPLAY": "${localEnv:WAYLAND_DISPLAY}",
        "XDG_RUNTIME_DIR": "/run/user/1000"
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-vscode.cpptools-extension-pack",
                "spencerwmiles.vscode-task-buttons"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/puffertank/venv/bin/python"
            }
        }
    },

    "postCreateCommand": "bash ./setup.sh"
}